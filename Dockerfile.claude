FROM debian:bookworm-slim

# Install runtime dependencies only — build-essential (gcc/make) is not needed
# by Claude Code and adds ~200MB to the image.
RUN apt-get update && apt-get install -y \
    curl \
    git \
    python3 \
    python3-venv \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user matching default Debian/Crostini UIDs before setting
# up the venv, so claudeuser owns it and can pip install during tasks.
RUN useradd -m -u 1000 -s /bin/bash claudeuser

# Install Claude Code. Pin to a specific version for reproducible image builds.
# Update this when you want to pull in new Claude Code features or model support.
# Find the latest version at: https://www.npmjs.com/package/@anthropic-ai/claude-code
RUN npm install -g @anthropic-ai/claude-code@latest

# Entrypoint restores ~/.claude.json from the backup inside the mounted
# credentials volume on every container start (see entrypoint.sh).
# Must be COPY'd and chmod'd here as root — after USER claudeuser these fail.
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create the Python venv as claudeuser so it has write access for pip installs.
# Also create the ~/.local/bin/claude symlink that Claude Code's doctor check
# expects — it looks for a user-local binary in addition to the global install.
USER claudeuser
RUN python3 -m venv /home/claudeuser/.venv && \
    mkdir -p /home/claudeuser/.local/bin && \
    ln -s /usr/bin/claude /home/claudeuser/.local/bin/claude
ENV PATH="/home/claudeuser/.venv/bin:$PATH"

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
