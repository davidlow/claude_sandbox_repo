# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Google AI Studio API key — enables Gemini cross-model audits in claude-yolo
# and the Gemini adversarial review phases in claude-architect, claude-qa,
# and claude-refactor. Get a key at https://aistudio.google.com/apikey
export GEMINI_API_KEY="your-key-here"
